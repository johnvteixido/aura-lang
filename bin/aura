#!/usr/bin/env ruby

require "aura"
require "fileutils"

def show_welcome
  puts <<~WELCOME
    🌟 Aura Framework v1.0 (Production Grade) 🌟
    Build AI-powered web apps at light speed.

    Usage: aura [command]
      aura run <file.aura>   - Run your Aura app
      aura check <file.aura> - Transpile and preview generated Ruby
      aura build <file.aura> - Export to a standalone Sinatra app
      aura init <name>       - Scaffold a new production project
      aura console           - Open the app console (Pry)
      aura --help            - Show this help
  WELCOME
end

if ARGV.empty?
  show_welcome
  exit
end

command  = ARGV[0]
filename = ARGV[1]

case command
when "run"
  if filename && File.exist?(filename)
    Aura.run_file(filename)
  else
    puts "😔 File not found: #{filename}."
    exit 1
  end

when "check"
  if filename && File.exist?(filename)
    puts Aura.transpile(File.read(filename))
  else
    puts "😔 File not found: #{filename}."
    exit 1
  end

when "build"
  if filename && File.exist?(filename)
    ruby_code = Aura.transpile(File.read(filename))
    out_file = filename.sub(".aura", ".rb")
    File.write(out_file, ruby_code)
    puts "✅ Built standalone application: #{out_file}"
    puts "🚀 Run with: ruby #{out_file}"
  else
    puts "😔 File not found: #{filename}."
    exit 1
  end

when "init"
  project_name = ARGV[1]
  if project_name.nil?
    puts "😔 Please provide a project name."
    exit 1
  end

  puts "🏗️  Scaffolding production project: #{project_name}..."
  FileUtils.mkdir_p(File.join(project_name, "models"))
  FileUtils.mkdir_p(File.join(project_name, "data"))
  FileUtils.mkdir_p(File.join(project_name, "public"))
  
  app_template = <<~AURA
    environment production do
      log_level :info
      device :cuda
    end

    model classifier neural_network do
      input shape(28, 28, 1) flatten
      layer dense units: 128, activation: :relu
      layer dropout rate: 0.2
      output units: 10, activation: :softmax
    end

    route "/v1/predict" post do
      output prediction from classifier.predict(image) format :json
    end

    run web on port: 8080
  AURA

  gemfile_template = <<~GEMFILE
    source 'https://rubygems.org'
    gem 'aura-lang'
    gem 'torch-rb'
    gem 'sinatra'
    gem 'puma'
    gem 'json'
    gem 'datasets'
  GEMFILE

  File.write(File.join(project_name, "app.aura"), app_template)
  File.write(File.join(project_name, "Gemfile"), gemfile_template)
  
  puts "✅ Project created! Now run:"
  puts "   cd #{project_name}"
  puts "   bundle install"
  puts "   aura run app.aura"

when "console"
  require "pry"
  puts "🔮 Aura Console (Production Context)"
  Pry.start

when "--help", "-h", "help"
  show_welcome

else
  puts "😔 Unknown command: #{command}."
  exit 1
end
