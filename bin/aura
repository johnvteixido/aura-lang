#!/usr/bin/env ruby

require "aura"
require "fileutils"

def show_welcome
  puts <<~WELCOME
    🌟 Aura Framework v1.1.0 (The Production Suite) 🌟
    Build, Train, and Deploy AI Apps.

    Usage: aura [command]
      aura run <file.aura>   - Run your Aura app
      aura check <file.aura> - Transpile and preview generated Ruby
      aura build <file.aura> - Export to a standalone Sinatra app
      aura deploy <file.aura> - Generate Docker deployment assets
      aura init <name>       - Scaffold a new production project
      aura console           - Open the app console (Pry)
      aura --help            - Show this help
  WELCOME
end

if ARGV.empty?
  show_welcome
  exit
end

command  = ARGV[0]
filename = ARGV[1]

case command
when "run"
  if filename && File.exist?(filename)
    Aura.run_file(filename)
  else
    puts "😔 File not found: #{filename}."
    exit 1
  end

when "check"
  if filename && File.exist?(filename)
    puts Aura.transpile(File.read(filename))
  else
    puts "😔 File not found: #{filename}."
    exit 1
  end

when "build"
  if filename && File.exist?(filename)
    ruby_code = Aura.transpile(File.read(filename))
    out_file = filename.sub(".aura", ".rb")
    File.write(out_file, ruby_code)
    puts "✅ Built standalone application: #{out_file}"
  else
    puts "😔 File not found: #{filename}."
    exit 1
  end

when "deploy"
  if filename && File.exist?(filename)
    Aura.build_docker(filename)
  else
    puts "😔 File not found: #{filename}."
    exit 1
  end

when "init"
  project_name = ARGV[1]
  if project_name.nil?
    puts "😔 Please provide a project name."
    exit 1
  end

  puts "🏗️  Scaffolding v1.1.0 project: #{project_name}..."
  FileUtils.mkdir_p(File.join(project_name, "models"))
  FileUtils.mkdir_p(File.join(project_name, "data"))
  
  app_template = <<~AURA
    environment production do
      device :cuda
      log_level :info
    end

    dataset "mnist" from huggingface "mnist" do
      shuffle true
      normalize true
    end

    model classifier neural_network do
      input shape(28, 28, 1) do
        resize 28
        to_tensor
      end
      
      layer conv2d filters: 32, kernel: 3
      layer flatten
      layer dense units: 128
      output units: 10, activation: :softmax

      save weights to "models/mnist.pth"
    end

    route "/predict" post do
      authenticate with :token
      output prediction from classifier.predict(image)
    end

    run web on port: 8080
  AURA

  File.write(File.join(project_name, "app.aura"), app_template)
  puts "✅ Project created! Use 'aura deploy app.aura' to containerize."

when "console"
  require "pry"
  Pry.start

when "--help", "-h", "help"
  show_welcome

else
  puts "😔 Unknown command: #{command}."
  exit 1
end
